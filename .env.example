# ============================================================
# Buchanan Family Construction — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# The marketing site runs without any of these set; the admin
# dashboard, phone agent, and notifications need them configured.
# ============================================================

# ---- Retell AI (phone number, speech-to-text, conversation, summary) ----
RETELL_API_KEY=
RETELL_AGENT_ID=
# Optional shared secret you append to the webhook URLs as ?secret=... to
# reject forged webhook calls (see app/api/retell/*).
RETELL_WEBHOOK_SECRET=

# ---- Supabase (toggle state + call log) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Twilio (SMS notifications to the owner) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # E.164, e.g. +12155550100

# ---- Resend (email notifications to the owner) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=         # verified sender, e.g. "Buchanan Family Construction <calls@yourdomain.com>"

# ---- Where notifications are delivered ----
NOTIFY_EMAIL=              # owner's email
NOTIFY_PHONE=              # owner's cell for SMS, E.164 e.g. +12155550100

# ---- Admin dashboard ----
ADMIN_PASSWORD=            # password for the /admin login gate
